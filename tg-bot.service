[Unit]
Description=Telegram AI Companion Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/tg_bot
EnvironmentFile=/opt/tg_bot/.env
ExecStart=/opt/tg_bot/venv/bin/python bot.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
