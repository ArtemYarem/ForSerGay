# Скопіюй цей файл у .env та заповни значення
# cp .env.example .env

# ── ОБОВ'ЯЗКОВО ────────────────────────────────────────────────
# Telegram Bot Token — отримай у @BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ── НЕОБОВ'ЯЗКОВО ──────────────────────────────────────────────
# Stable Horde API Key
# Без ключа — анонімний режим (повільніше, але безкоштовно)
# Зареєструватись: https://stablehorde.net/register
HORDE_API_KEY=0000000000
